# Server
PORT=3000
NODE_ENV=development

# DEV ONLY — set to true to bypass Google OAuth and access /admin without login
# Never set this in production (it is automatically blocked when NODE_ENV=production)
ADMIN_BYPASS=true

# SQLite — path relative to apps/api/
DATABASE_URL=./data/app.db

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_REFRESH_SECRET=change-me-too-use-a-different-long-random-string
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# Google OAuth — get from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Admin whitelist (comma-separated, no spaces)
ADMIN_EMAILS=you@gmail.com

# Frontend base URL (used for CORS + OAuth redirect)
SHARE_BASE_URL=http://localhost:5173
